// Bugsnag key 模板。新机器/新成员请把本文件拷贝改名为 BugsnagSecrets.swift,
// 然后到 Bugsnag 后台分别新建三个 project,把对应 key 填进下方占位。
// BugsnagSecrets.swift 已在 .gitignore 里,不会上传。

import Foundation

enum BugsnagSecrets {
    static func apiKey(for platform: BugsnagPlatform) -> String? {
        switch platform {
        case .iOS:   return nil // 填入 iOS project 的 API key
        case .macOS: return nil // 填入 macOS project 的 API key
        case .tvOS:  return nil // 填入 tvOS project 的 API key
        }
    }
}
